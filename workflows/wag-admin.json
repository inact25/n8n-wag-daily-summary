    {
      "parameters": {
        "method": "GET",
        "url": "={{ ($('Admin Form').item.json['go-wa base URL'] || $('Get Config').first().json.gowa_base_url || 'http://localhost:3000').replace(/\\/$/, '') }}/user/my/groups",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Device-Id",
              "value": "={{ ($('Admin Form').item.json['go-wa device id'] || $('Get Config').first().json.gowa_device_id || '') }}"
            }
          ]
        },
        "options": {}
      },
      "id": "ad-gowa",
      "name": "go-wa: List Groups",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        280,
        -150
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "REPLACE_WITH_GOWA_BASIC_CRED_ID",
          "name": "go-wa basic auth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const r = $json;\nconst res = r.results || r;\nlet arr = res.groups || res.data || (Array.isArray(res) ? res : []);\nif (!Array.isArray(arr)) arr = [];\nconst lines = arr.map(g => '• ' + (g.Name || g.subject || g.name || g.Subject || '(tanpa nama)') + '  —  ' + (g.JID || g.id || g.jid || ''));\nconst resultMessage = arr.length\n  ? ('Ditemukan ' + arr.length + ' grup. Salin JID (…@g.us) lalu pakai aksi \"' + 'Save group (add or update)' + '\":\\n\\n' + lines.join('\\n'))\n  : 'go-wa tidak mengembalikan grup. Cek kredensial / URL go-wa.';\nreturn [{ json: { resultMessage } }];"
      },
      "id": "ad-fmt-gowa",
      "name": "Format go-wa Groups",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        -150
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO wag_groups (chat_jid, project_name, send_to, active)\nVALUES ($1,$2,$3,$4)\nON CONFLICT (chat_jid) DO UPDATE SET\n  project_name = EXCLUDED.project_name,\n  send_to = EXCLUDED.send_to,\n  active = EXCLUDED.active",
        "options": {
          "queryReplacement": "={{ [ $('Admin Form').item.json['Chat JID'], $('Admin Form').item.json['Project name'], $('Admin Form').item.json['Send to number'], ($('Admin Form').item.json['Active'] || 'Yes') === 'Yes' ] }}"
        }
      },
