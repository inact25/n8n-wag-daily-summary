      "id": "ad-gowa2",
      "name": "go-wa: List Groups (bulk)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        280,
        500
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "REPLACE_WITH_GOWA_BASIC_CRED_ID",
          "name": "go-wa basic auth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const r = $json;\nconst res = r.results || r;\nlet arr = res.groups || res.data || (Array.isArray(res) ? res : []);\nif (!Array.isArray(arr)) arr = [];\nconst sendTo = $('Admin Form').first().json['Send to number'];\nif (!sendTo) throw new Error('Isi kolom \"Send to number\" untuk bulk register (dipakai untuk semua grup).');\nconst rows = arr\n  .map(g => {\n    const jid = g.JID || g.id || g.jid || '';\n    const raw = String(g.Name || g.subject || g.name || g.Subject || '').trim();\n    // go-wa returns the subject in Name; ignore blanks and the \"Group\" placeholder\n    // (sent before the device syncs metadata) so we do not store junk names.\n    const name = (raw && raw.toLowerCase() !== 'group') ? raw : ('Grup ' + String(jid).split('@')[0].slice(-4));\n    return { chat_jid: jid, project_name: name, send_to: sendTo };\n  })\n  .filter(x => String(x.chat_jid).endsWith('@g.us'));\nif (!rows.length) throw new Error('go-wa tidak mengembalikan grup untuk didaftarkan.');\nreturn rows.map(x => ({ json: x }));"
      },
      "id": "ad-map",
      "name": "Map Groups to Rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        500
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO wag_groups (chat_jid, project_name, send_to, active)\nVALUES ($1,$2,$3,$4)\nON CONFLICT (chat_jid) DO UPDATE SET\n  project_name = EXCLUDED.project_name,\n  send_to = EXCLUDED.send_to,\n  active = EXCLUDED.active",
        "options": {
          "queryReplacement": "={{ [ $json.chat_jid, $json.project_name, $json.send_to, true ] }}"
        }
      },
      "id": "ad-bulk",
      "name": "Bulk Upsert Groups",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
