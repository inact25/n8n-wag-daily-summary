    {
      "parameters": {
        "jsCode": "const n = $('Map Groups to Rows').all().length;\nconst resultMessage = '✅ ' + n + ' grup didaftarkan (semua ringkasan dikirim ke nomor yang sama). ' +\n  'Sesuaikan penerima per grup lewat aksi \"Save group (add or update)\", atau nonaktifkan yang tak perlu.';\nreturn [{ json: { resultMessage } }];"
      },
