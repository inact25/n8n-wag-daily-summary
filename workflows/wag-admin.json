              "id": "ad-msg-install-a",
              "name": "resultMessage",
              "type": "string",
              "value": "✅ Database schema installed / verified.\nTables: wag_groups, wag_messages, wag_summaries.\nNext: use \"Show WhatsApp groups (from go-wa)\" then \"Save group (add or update)\" to register groups."
            }
          ]
        },
        "options": {}
      },
