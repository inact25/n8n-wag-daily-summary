{
  "name": "WAG Chat — Admin / Setup Wizard",
  "nodes": [
    {
      "parameters": {
        "formTitle": "WAG Chat — Manage Groups (Advanced)",
        "formDescription": "Advanced tools. Most people should use the \"Quick Setup\" workflow instead. Here you can install the database, list your WhatsApp groups to find a Chat JID (looks like 1203...@g.us), and add / update / remove a single group. Fill only the fields your chosen action needs.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Action",
              "fieldType": "dropdown",
              "requiredField": true,
              "fieldOptions": {
                "values": [
                  {
                    "option": "Install database schema"
                  },
                  {
                    "option": "Show WhatsApp groups (from go-wa)"
                  },
                  {
                    "option": "Save group (add or update)"
                  },
                  {
                    "option": "Register ALL WhatsApp groups (bulk)"
                  },
                  {
                    "option": "List registered groups"
                  },
                  {
                    "option": "Remove group"
                  }
                ]
              }
            },
            {
              "fieldLabel": "Chat JID",
              "fieldType": "text",
              "placeholder": "1203...@g.us"
            },
            {
              "fieldLabel": "Project name",
              "fieldType": "text",
              "placeholder": "WHNYHProject"
            },
            {
              "fieldLabel": "Send to number",
              "fieldType": "text",
              "placeholder": "6285609200000"
            },
            {
              "fieldLabel": "Active",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  {
                    "option": "Yes"
                  },
                  {
                    "option": "No"
                  }
                ]
              }
            },
            {
              "fieldLabel": "go-wa base URL",
              "fieldType": "text",
              "placeholder": "http://localhost:3000"
            }
          ]
        },
        "options": {}
      },
