      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "REPLACE_WITH_POSTGRES_CRED_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const updated = $('Update Names').all().map(i => i.json).filter(r => r && r.chat_jid);\nconst head = updated.slice(0, 15).map(r => '• ' + r.project_name + '  (' + r.chat_jid + ')').join('\\n');\nconst resultMessage = updated.length\n  ? ('✅ Refreshed names for ' + updated.length + ' registered group(s) from go-wa:\\n\\n' + head +\n     (updated.length > 15 ? '\\n… and ' + (updated.length - 15) + ' more.' : ''))\n  : 'No registered groups matched the go-wa list — nothing to update. (Names are only refreshed for groups already in wag_groups.)';\nreturn [{ json: { resultMessage } }];"
      },
