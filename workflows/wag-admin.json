    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json).filter(r => r && r.chat_jid);\nconst resultMessage = rows.length\n  ? ('Grup terdaftar (' + rows.length + '):\\n\\n' + rows.map(r =>\n      (r.active ? '🟢' : '⚪') + ' ' + r.project_name + '\\n    ' + r.chat_jid + '  →  ' + r.send_to).join('\\n'))\n  : 'Belum ada grup terdaftar. Gunakan aksi \"Save group (add or update)\".';\nreturn [{ json: { resultMessage } }];"
      },
      "id": "ad-fmt-list",
      "name": "Format Registered",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        150
