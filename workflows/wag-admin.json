    {
      "parameters": {
        "jsCode": "const r = $json;\nconst res = r.results || r;\nlet arr = res.groups || res.data || (Array.isArray(res) ? res : []);\nif (!Array.isArray(arr)) arr = [];\nconst rows = arr.map(g => {\n  const jid = g.JID || g.id || g.jid || '';\n  const name = g.Name || g.subject || g.name || g.Subject || '';\n  return { chat_jid: jid, project_name: String(name).trim() };\n}).filter(x => String(x.chat_jid).endsWith('@g.us') && x.project_name && x.project_name.toLowerCase() !== 'group');\nif (!rows.length) throw new Error('go-wa returned no usable group names. If names are still blank, the device may not have synced group metadata yet — try again later.');\nreturn rows.map(x => ({ json: x }));"
      },
      "id": "ad-map-ref",
      "name": "Map Names",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        800
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE wag_groups SET project_name = $2 WHERE chat_jid = $1 RETURNING chat_jid, project_name",
        "options": {
          "queryReplacement": "={{ [ $json.chat_jid, $json.project_name ] }}"
        }
      },
