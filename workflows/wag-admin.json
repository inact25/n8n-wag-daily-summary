    {
      "parameters": {
        "jsCode": "const r = $json;\nconst res = r.results || r;\nlet arr = res.groups || res.data || (Array.isArray(res) ? res : []);\nif (!Array.isArray(arr)) arr = [];\nconst sample = arr.slice(0, 3);\nconst firstKeys = sample.length ? Object.keys(sample[0]) : [];\nconst resultMessage =\n  'go-wa returned ' + arr.length + ' groups.\\n' +\n  'Wrapper keys: ' + Object.keys(r).join(', ') + '\\n' +\n  'First group keys: ' + firstKeys.join(', ') + '\\n\\n' +\n  'First ' + sample.length + ' raw group object(s):\\n' +\n  JSON.stringify(sample, null, 2);\nreturn [{ json: { resultMessage } }];"
      },
