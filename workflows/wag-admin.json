                    "option": "Yes"
                  },
                  {
                    "option": "No"
                  }
                ]
              }
            },
            {
              "fieldLabel": "go-wa base URL",
              "fieldType": "text",
              "placeholder": "blank = use saved wag_config value"
            },
            {
              "fieldLabel": "go-wa device id",
              "fieldType": "text",
              "placeholder": "blank = use saved wag_config value"
            }
          ]
        },
        "options": {}
