# Copy to .env and edit. Used by docker-compose.yml.
# (.env is gitignored — never commit real secrets.)

# --- PostgreSQL (stores wag_groups / wag_messages / wag_summaries) ---
POSTGRES_USER=wag
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=wag

# --- go-wa (WhatsApp gateway) HTTP Basic Auth ---
# The same values go into the n8n "go-wa basic auth" credential.
GOWA_USER=admin
GOWA_PASS=change-me-gowa

# --- App config surfaced to the n8n workflows as env vars ---
# Inside the compose network n8n reaches go-wa at http://gowa:3000.
GOWA_BASE_URL=http://gowa:3000
# Number that receives failure alerts (digits only, no +).
WAG_ALERT_TO=6285609200000

# --- Timezone (used by n8n schedule + summaries) ---
TZ=Asia/Jakarta
